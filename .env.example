# ── Database ──────────────────────────────────────────────────────────────────
# Local (host): docker compose up -d db
DATABASE_URL=postgresql://opencrm:opencrm@localhost:5432/opencrm

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — use a long random string (32+ characters)
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Public URL of this app (must match how users reach it in the browser)
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# NODE_ENV=development
