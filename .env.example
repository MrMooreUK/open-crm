# ── Database ──────────────────────────────────────────────────────────────────
# Local (host connecting to compose DB on loopback):
DATABASE_URL=postgresql://opencrm:opencrm@localhost:5432/opencrm

# Optional: override the demo Postgres password used by docker compose
# POSTGRES_PASSWORD=opencrm

# ── Auth (required in production) ─────────────────────────────────────────────
# Long random secret (32+ characters). Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Public URL of this app (must match how users reach it in the browser)
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# NODE_ENV=development
